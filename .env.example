# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://quant:quant@localhost:5432/quant_platform"

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-in-production"
# Access token TTL (seconds)
JWT_ACCESS_TTL=900
# Refresh token TTL (seconds)
JWT_REFRESH_TTL=604800

# ── Exchange key encryption ──────────────────────────────────────────────────
# AES-256-GCM — must be a 32-byte value; generate with: openssl rand -hex 32
EXCHANGE_KEY_ENC_SECRET="change-me-in-production-32-bytes!!"

# ── AI providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
OPENROUTER_API_KEY=""
GROQ_API_KEY=""

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT=3001
WORKER_PORT=3002
# Comma-separated allowed origins for CORS
CORS_ORIGIN="http://localhost:3000"
